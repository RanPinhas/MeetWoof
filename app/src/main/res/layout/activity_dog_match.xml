<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#fde7d0"
    android:layoutDirection="ltr"
    tools:context=".DogMatchActivity">

    <include
        android:id="@+id/bottomNavBar"
        layout="@layout/layout_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true" />

    <ImageView
        android:id="@+id/imgLikeIndicator"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/img_paw"
        app:tint="#4CAF50"
        android:layout_centerInParent="true"
        android:layout_marginStart="20dp"
        android:alpha="0"
        android:visibility="invisible"/>

    <ImageView
        android:id="@+id/imgPassIndicator"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        app:tint="#F44336"
        android:layout_centerInParent="true"
        android:layout_marginEnd="20dp"
        android:alpha="0"
        android:visibility="invisible"/>

    <androidx.cardview.widget.CardView
        android:id="@+id/cardDogProfile"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_alignParentTop="true"
        android:layout_above="@id/bottomNavBar"
        android:layout_margin="16dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="4dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/imgDog"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/img_logo"
                android:scaleType="centerCrop"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:layout_alignParentBottom="true"
                android:background="@drawable/gradient_black_transparent"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvDogName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bruno"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"/>

                    <TextView
                        android:id="@+id/tvDogAge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=", 3"
                        android:textSize="28sp"
                        android:textColor="#FFFFFF"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvDogBreed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Golden Retriever • 2km away"
                    android:textSize="16sp"
                    android:textColor="#E0E0E0"/>
            </LinearLayout>

            <ImageButton
                android:id="@+id/btnInfo"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentEnd="true"
                android:layout_alignParentBottom="true"
                android:layout_margin="20dp"
                android:background="@drawable/circle_white_bg"
                android:src="@android:drawable/ic_menu_info_details"
                app:tint="#6d112a"/>

        </RelativeLayout>
    </androidx.cardview.widget.CardView>

</RelativeLayout>