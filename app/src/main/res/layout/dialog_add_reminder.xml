<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/rounded_bottom_sheet_bg"
    android:orientation="vertical"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="X"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#6d112a"
            android:backgroundTint="#e3cab4"
            app:cornerRadius="20dp"
            android:minWidth="0dp"
            android:paddingHorizontal="20dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="New Reminder"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#6d112a"
            android:layout_marginStart="16dp"/>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="For which dog?"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#6d112a"
        android:layout_marginBottom="4dp"/>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#f5f5f5"
        android:padding="4dp"
        android:layout_marginBottom="16dp">
        <Spinner
            android:id="@+id/spDogSelector"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:spinnerMode="dropdown"/>
    </RelativeLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Title (e.g., Vet Appointment)"
        android:layout_marginBottom="12dp"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textCapSentences"/>
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Description"
        android:layout_marginBottom="16dp"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textMultiLine"
            android:minLines="2"/>
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.materialswitch.MaterialSwitch
        android:id="@+id/switchSetDate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Set Date &amp; Time Alarm"
        android:textSize="16sp"
        android:textColor="#6d112a"
        android:checked="true"
        android:layout_marginBottom="8dp"/>

    <LinearLayout
        android:id="@+id/layoutDateTimeContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:animateLayoutChanges="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btnPickDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Pick Date"
                android:backgroundTint="#e3cab4"
                android:textColor="#6d112a"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnPickTime"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Pick Time"
                android:backgroundTint="#e3cab4"
                android:textColor="#6d112a"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvSelectedDateTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Default: Today"
            android:textAlignment="center"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#6d112a"
            android:background="#F0F0F0"
            android:padding="8dp"
            android:layout_marginBottom="24dp"/>
    </LinearLayout>

    <Button
        android:id="@+id/btnSaveReminder"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Save Task"
        android:textSize="18sp"
        android:textStyle="bold"
        android:backgroundTint="#6d112a"
        android:textColor="#FFFFFF"
        app:cornerRadius="12dp"/>

</LinearLayout>