<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#fde7d0"
    android:layoutDirection="ltr"
    tools:context=".DogReviewsActivity">

    <RelativeLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#e3cab4"
        android:padding="16dp"
        android:elevation="4dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_revert"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="#6d112a"
            android:layout_centerVertical="true"/>

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/btnBack"
            android:layout_marginStart="16dp"
            android:layout_centerVertical="true"
            android:text="Dog Reviews"
            android:fontFamily="@font/rammetto_one"
            android:textColor="#6d112a"
            android:textSize="20sp"
            android:maxLines="1"
            android:ellipsize="end"/>
    </RelativeLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvDogReviews"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header"
        android:clipToPadding="false"
        android:padding="16dp"/>

    <TextView
        android:id="@+id/tvEmptyReviews"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:text="No reviews yet for this dog."
        android:textSize="18sp"
        android:textColor="#886d112a"
        android:gravity="center"
        android:visibility="gone"
        tools:visibility="visible"/>

</RelativeLayout>