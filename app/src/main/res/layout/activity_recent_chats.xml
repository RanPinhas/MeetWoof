<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#fde7d0"
    android:layoutDirection="ltr"
    tools:context=".RecentChatsActivity">

    <RelativeLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#e3cab4"
        android:padding="16dp"
        android:elevation="4dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_revert"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="#6d112a"
            android:layout_centerVertical="true"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/btnBack"
            android:layout_toStartOf="@+id/btnMyReviews"
            android:layout_marginStart="16dp"
            android:layout_centerVertical="true"
            android:text="My Matches"
            android:fontFamily="@font/rammetto_one"
            android:textColor="#6d112a"
            android:textSize="24sp"
            android:maxLines="1"
            android:ellipsize="end"/>

        <ImageButton
            android:id="@+id/btnMyReviews"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:src="@android:drawable/btn_star"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="#6d112a"/>

    </RelativeLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvRecentChats"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header"
        android:padding="16dp"
        android:clipToPadding="false"/>

    <TextView
        android:id="@+id/tvEmptyChats"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:text="No matches yet... \nGo swipe some dogs! 🐶"
        android:textSize="18sp"
        android:textColor="#886d112a"
        android:gravity="center"
        android:fontFamily="@font/allerta"
        android:visibility="gone"
        tools:visibility="visible"/>

</RelativeLayout>