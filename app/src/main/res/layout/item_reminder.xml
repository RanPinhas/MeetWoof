<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <CheckBox
            android:id="@+id/cbReminderDone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:buttonTint="#6d112a"
            android:layout_marginEnd="12dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvReminderTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Vet Appointment"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#333333"/>

            <TextView
                android:id="@+id/tvReminderDesc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Annual vaccine"
                android:textSize="14sp"
                android:textColor="#757575"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvReminderDogName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bruno"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#6d112a"
                    android:background="#fde7d0"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="4dp"
                    app:cornerRadius="4dp"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/tvReminderTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="12/05/2026 10:00"
                    android:textSize="12sp"
                    android:textColor="#9E9E9E"/>
            </LinearLayout>
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnDeleteReminder"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_delete"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="#F44336"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>